.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E5E7EB;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  transition: all 0.2s;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
  opacity: 0.5;
}

.tab-label {
  font-size: 20rpx;
  color: #8C8C8C;
  line-height: 1.2;
}

.tab-bar-item.active .tab-icon {
  opacity: 1;
  transform: scale(1.1);
}

.tab-bar-item.active .tab-label {
  color: #1A56DB;
  font-weight: 600;
}
