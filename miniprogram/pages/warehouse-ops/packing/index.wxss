.page-title { font-size: var(--font-size-xl); font-weight: 700; display: block; }
.page-desc { font-size: var(--font-size-sm); color: var(--color-text-secondary); display: block; margin-top: 4rpx; }
.form-picker { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; border: 2rpx solid var(--color-border); border-radius: var(--radius-md); background: var(--color-bg-card); font-size: var(--font-size-base); }
.picker-arrow { color: var(--color-text-placeholder); }
.bom-preview { margin-top: 20rpx; padding: 20rpx; background: #EFF6FF; border-radius: var(--radius-md); }
.bom-title { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-primary); display: block; margin-bottom: 12rpx; }
.bom-item { display: flex; align-items: center; padding: 8rpx 0; font-size: var(--font-size-sm); }
.bom-name { flex: 1; }
.bom-consume { color: var(--color-primary); margin-right: 16rpx; }
.bom-stock { color: var(--color-text-secondary); font-size: var(--font-size-xs); }
.bom-stock.insufficient { color: var(--color-danger); font-weight: 600; }
.record-item { padding: 24rpx 32rpx !important; }
.record-sku { font-size: var(--font-size-base); font-weight: 500; }
.record-date { font-size: var(--font-size-xs); color: var(--color-text-placeholder); }
.record-detail { margin-top: 8rpx; font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.record-qty { font-weight: 700; color: var(--color-primary); }
.record-loss { color: var(--color-danger); display: block; margin-top: 4rpx; }
.record-operator { font-size: var(--font-size-xs); color: var(--color-text-placeholder); display: block; margin-top: 4rpx; }
