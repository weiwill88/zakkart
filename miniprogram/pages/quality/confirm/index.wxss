.verdict-options { display: flex; flex-direction: column; gap: 12rpx; }
.verdict-option { display: flex; align-items: center; padding: 24rpx; border: 2rpx solid var(--color-border); border-radius: var(--radius-lg); transition: all 0.2s; }
.verdict-option:active { opacity: 0.8; }
.verdict-option.selected { border-width: 3rpx; }
.verdict-option.selected.pass { border-color: #059669; background: #ECFDF5; }
.verdict-option.selected.partial { border-color: #D97706; background: #FFFBEB; }
.verdict-option.selected.reject { border-color: #DC2626; background: #FEF2F2; }
.verdict-icon { font-size: 40rpx; margin-right: 16rpx; flex-shrink: 0; }
.verdict-label { font-size: var(--font-size-base); font-weight: 600; margin-right: 12rpx; }
.verdict-desc { font-size: var(--font-size-sm); color: var(--color-text-secondary); flex: 1; }

.defect-auto { display: flex; align-items: baseline; gap: 8rpx; padding: 16rpx 0; }
.defect-qty { font-size: 48rpx; font-weight: 700; color: #DC2626; }
.defect-note { font-size: var(--font-size-sm); color: var(--color-text-secondary); }

.defect-types { display: flex; flex-wrap: wrap; gap: 12rpx; }
.defect-type-item { display: flex; align-items: center; gap: 6rpx; padding: 10rpx 20rpx; border: 2rpx solid var(--color-border); border-radius: var(--radius-full); font-size: var(--font-size-sm); }
.defect-type-item.checked { border-color: #DC2626; background: #FEF2F2; color: #DC2626; }
.defect-type-icon { font-size: 24rpx; }

.upload-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12rpx; }
.upload-item { aspect-ratio: 1; border: 2rpx dashed #D1D5DB; border-radius: var(--radius-md); display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--color-bg-page); }
.upload-item:active { background: #E5E7EB; }
.upload-icon { font-size: 40rpx; }
.upload-text { font-size: 20rpx; color: #9CA3AF; margin-top: 4rpx; }

.handle-options { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }
.handle-option { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 24rpx 12rpx; border: 2rpx solid var(--color-border); border-radius: var(--radius-lg); }
.handle-option.selected { border-color: var(--color-primary); background: #EFF6FF; }
.handle-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.handle-name { font-size: var(--font-size-base); font-weight: 500; }
.handle-desc { font-size: 20rpx; color: var(--color-text-secondary); margin-top: 4rpx; line-height: 1.3; }

.pass-action { padding: 20rpx; background: #ECFDF5; border-radius: var(--radius-md); }
.pass-text { font-size: var(--font-size-base); display: block; }
.pass-note { font-size: var(--font-size-sm); color: #6B7280; display: block; margin-top: 8rpx; line-height: 1.5; }
