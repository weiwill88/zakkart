<!--pages/product/list/index.wxml - 产品列表-->
<view class="page-container">
  <view wx:for="{{products}}" wx:key="id" class="card" bindtap="goToDetail" data-id="{{item.id}}">
    <view class="flex-between" style="margin-bottom: 12rpx">
      <view>
        <text style="font-size: 28rpx; font-weight: 600; display: block">{{item.name}}</text>
        <text style="font-size: 24rpx; color: #6B7280; display: block; margin-top: 4rpx">{{item.code}} · {{item.nameEn}}</text>
      </view>
      <view class="badge {{item.isSimple ? 'badge-pending' : 'badge-in-progress'}}">{{item.isSimple ? '简易产品' : '组装产品'}}</view>
    </view>
    <view style="display: flex; gap: 16rpx; margin-top: 12rpx">
      <view style="flex: 1; text-align: center; padding: 12rpx; background: #F3F4F6; border-radius: 12rpx">
        <text style="font-size: 32rpx; font-weight: 700; color: #1A56DB; display: block">{{item.skuCount}}</text>
        <text style="font-size: 22rpx; color: #6B7280">SKU</text>
      </view>
      <view style="flex: 1; text-align: center; padding: 12rpx; background: #F3F4F6; border-radius: 12rpx">
        <text style="font-size: 32rpx; font-weight: 700; color: #059669; display: block">{{item.bomParts}}</text>
        <text style="font-size: 22rpx; color: #6B7280">配件</text>
      </view>
    </view>
  </view>
</view>