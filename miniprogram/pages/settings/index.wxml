<!--pages/settings/index.wxml - 我的/设置-->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="card user-card" style="border-left: 6rpx solid {{roleColor}}">
    <view class="user-info">
      <view class="user-avatar" style="background: {{roleColor}}">
        <text>{{user.name[0]}}</text>
      </view>
      <view class="user-detail">
        <text class="user-name">{{user.name}}</text>
        <text class="user-role" style="color: {{roleColor}}">{{user.roleName}}</text>
        <text class="user-org">{{user.org.name}}</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section-header">
    <text class="section-title">系统功能</text>
  </view>
  <view class="menu-list card">
    <view class="menu-item" wx:if="{{currentRole === 'admin'}}" bindtap="goToProducts">
      <text class="menu-icon">📦</text>
      <text class="menu-label">产品管理</text>
      <view class="list-item-arrow"></view>
    </view>
    <view class="menu-item" wx:if="{{currentRole === 'admin'}}" bindtap="goToSuppliers">
      <text class="menu-icon">🏭</text>
      <text class="menu-label">供应商管理</text>
      <view class="list-item-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToNotifications">
      <text class="menu-icon">🔔</text>
      <text class="menu-label">通知记录</text>
      <view class="list-item-arrow"></view>
    </view>
    <view class="menu-item" wx:if="{{supplierModuleAccess.org}}" bindtap="goToOrgManage">
      <text class="menu-icon">👥</text>
      <text class="menu-label">我的组织与成员</text>
      <view class="list-item-arrow"></view>
    </view>
    <view class="menu-item" wx:if="{{currentRole === 'admin'}}">
      <text class="menu-icon">⚙️</text>
      <text class="menu-label">提醒规则配置</text>
      <text class="menu-tag">待开发</text>
    </view>
  </view>

  <view class="version-info">
    <text>Zakkart 供应链管理系统 v0.1.0</text>
  </view>

  <supplier-module-nav currentKey="settings" />
</view>
