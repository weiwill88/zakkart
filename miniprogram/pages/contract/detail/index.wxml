<!--pages/contract/detail/index.wxml - 合同详情-->
<view class="page-container">
  <!-- 合同头部信息 -->
  <view class="card contract-header-card">
    <view class="flex-between">
      <text class="contract-no">{{contract.contractNo}}</text>
      <view class="badge {{contract.statusClass}}">{{contract.statusText}}</view>
    </view>
    <text class="contract-product">{{contract.productName}}</text>
    <view style="margin-bottom: 24rpx">
      <view class="badge {{contract.supplierConfirmClass}}">{{contract.supplierConfirmText}}</view>
    </view>

    <view class="info-grid">
      <view class="info-cell">
        <text class="info-label">供应商</text>
        <text class="info-value">{{contract.supplierName}}</text>
      </view>
      <view class="info-cell">
        <text class="info-label">签订日期</text>
        <text class="info-value">{{contract.signDate}}</text>
      </view>
      <view class="info-cell">
        <text class="info-label">合同总量</text>
        <text class="info-value highlight">{{contract.totalQtyStr}}</text>
      </view>
      <view class="info-cell">
        <text class="info-label">已发货量</text>
        <text class="info-value">{{contract.deliveredQtyStr}}</text>
      </view>
    </view>

    <view class="progress-section">
      <view class="progress-info">
        <text class="progress-text">总交付进度</text>
        <text class="progress-percent">{{contract.progress}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{contract.progress}}%"></view>
      </view>
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">合同确认</text>
  </view>
  <view class="card batch-card">
    <view class="info-row"><text class="info-label">确认状态</text><text class="info-value">{{contract.supplierConfirmText}}</text></view>
    <view class="info-row"><text class="info-label">确认时间</text><text class="info-value">{{contract.supplierConfirmedAt}}</text></view>
    <text style="font-size: 24rpx; color: #6B7280; display: block; margin-top: 12rpx">当前以系统合同详情作为在线查阅页面，正式签署仍在线下电子签平台完成。</text>
    <view wx:if="{{isSupplier && contract.canConfirm}}" class="batch-actions">
      <button class="btn btn-primary btn-block" bindtap="onConfirmContract">确认内容无误</button>
    </view>
    <view wx:if="{{contract.signedPdfFileId}}" class="batch-actions">
      <button class="btn btn-outline btn-block" bindtap="onViewSignedPdf">查看已签 PDF</button>
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">合同原文</text>
  </view>
  <view class="card document-card">
    <view class="document-title-row">
      <text class="document-contract-no">合同编号：{{contract.contractNo}}</text>
      <text class="document-title">采购合同</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">甲方信息</text>
      <text class="document-line">采购方（甲方）：{{contract.document.buyerInfo.name}}</text>
      <text class="document-line">法定代表人：{{contract.document.buyerInfo.legal_person}}</text>
      <text class="document-line">统一社会信用代码：{{contract.document.buyerInfo.credit_code}}</text>
      <text class="document-line">地址：{{contract.document.buyerInfo.address}}</text>
      <text class="document-line">联系方式：{{contract.document.buyerInfo.phone}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">乙方信息</text>
      <text class="document-line">供货方（乙方）：{{contract.document.supplierName}}</text>
      <text class="document-line">法定代表人：{{contract.document.supplierLegalPerson}}</text>
      <text class="document-line">统一社会信用代码：{{contract.document.supplierCreditCode}}</text>
      <text class="document-line">地址：{{contract.document.supplierAddress}}</text>
      <text class="document-line">联系方式：{{contract.document.supplierPhone}}</text>
    </view>

    <view class="document-section">
      <text class="document-paragraph">{{contract.document.preamble}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">一、采购货物说明：{{contract.document.productDesc}}</text>
      <scroll-view scroll-x class="doc-table-scroll">
        <view class="doc-table settlement-table">
          <view class="doc-table-header">
            <text class="doc-cell">产品型号</text>
            <text class="doc-cell xl">采购数量</text>
            <text class="doc-cell">采购单价</text>
            <text class="doc-cell">采购金额</text>
          </view>
          <view wx:for="{{contract.document.settlementItems}}" wx:key="rowId" class="doc-table-row">
            <text class="doc-cell">{{item.model}}</text>
            <text class="doc-cell xl">{{item.qtyDetail}}</text>
            <text class="doc-cell">{{item.unitPrice}}</text>
            <text class="doc-cell">{{item.amount}}</text>
          </view>
          <view class="doc-table-row total">
            <text class="doc-cell total-label" style="flex: 3">合计采购总金额（含税）</text>
            <text class="doc-cell">{{contract.document.grandTotal}}</text>
          </view>
        </view>
      </scroll-view>
      <scroll-view scroll-x class="doc-table-scroll">
        <view class="doc-table spec-table">
          <view class="doc-table-header">
            <text class="doc-cell">产品型号</text>
            <text class="doc-cell xl">规格或尺寸</text>
            <text class="doc-cell">材质</text>
            <text class="doc-cell">重量</text>
            <text class="doc-cell">颜色</text>
          </view>
          <view wx:for="{{contract.document.specItems}}" wx:key="rowId" class="doc-table-row">
            <text class="doc-cell">{{item.model}}</text>
            <text class="doc-cell xl">{{item.size}}</text>
            <text class="doc-cell">{{item.material}}</text>
            <text class="doc-cell">{{item.weight}}</text>
            <text class="doc-cell">{{item.color}}</text>
          </view>
        </view>
      </scroll-view>
      <text class="document-line">1. 采购结算主表如上。</text>
      <text class="document-line">2. 规格说明表如上。</text>
      <text class="document-line">3. 成品货物要求：{{contract.document.qualityClause}}</text>
      <text class="document-line">4. 乙方负责本合同产品生产的原材料有：{{contract.document.rawMaterials || '—'}}</text>
      <text class="document-line">5. {{contract.document.variationClause}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">二、产品采购下单方式及产品交付时间</text>
      <text class="document-line">{{contract.document.deliveryClause}}</text>
      <scroll-view scroll-x class="doc-table-scroll">
        <view class="doc-table wide">
          <view class="doc-table-header">
            <text class="doc-cell">交付提货时间</text>
            <text wx:for="{{contract.document.deliveryHeaders}}" wx:key="*this" class="doc-cell">{{item}}</text>
            <text class="doc-cell">总数量</text>
          </view>
          <view wx:for="{{contract.document.deliveryRows}}" wx:for-item="deliveryRow" wx:key="date" class="doc-table-row">
            <text class="doc-cell">{{deliveryRow.date}}</text>
            <text wx:for="{{deliveryRow.quantities}}" wx:for-item="quantity" wx:key="index" class="doc-cell">{{quantity}}</text>
            <text class="doc-cell">{{deliveryRow.rowTotal}}</text>
          </view>
          <view class="doc-table-row total">
            <text class="doc-cell">总数</text>
            <text wx:for="{{contract.document.deliveryTotals}}" wx:key="index" class="doc-cell">{{item}}</text>
            <text class="doc-cell">{{contract.document.deliveryGrandTotal}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="document-section">
      <text class="document-subtitle">三、产品合格率与产品返工要求</text>
      <text class="document-paragraph">{{contract.document.qualityGuaranteeClause}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">四、支付方式</text>
      <text wx:for="{{contract.document.paymentClauseLines}}" wx:key="index" class="document-line">{{item}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">五、增值税专用发票开票信息</text>
      <text wx:for="{{contract.document.invoiceClauseLines}}" wx:key="index" class="document-line">{{item}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">六、甲方的权利与责任</text>
      <text wx:for="{{contract.document.section6Lines}}" wx:key="index" class="document-line">{{item}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">七、乙方的权利与责任</text>
      <text wx:for="{{contract.document.section7Lines}}" wx:key="index" class="document-line">{{item}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">八、法律适用与争议的解决</text>
      <text wx:for="{{contract.document.section8Lines}}" wx:key="index" class="document-line">{{item}}</text>
    </view>

    <view class="document-section">
      <text class="document-subtitle">九、合同生效、变更及终止</text>
      <text wx:for="{{contract.document.section9Lines}}" wx:key="index" class="document-line">{{item}}</text>
    </view>
  </view>
</view>
