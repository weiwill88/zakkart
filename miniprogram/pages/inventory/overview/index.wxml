<!--pages/inventory/overview/index.wxml - 库存总览-->
<view class="page-container">
  <view class="tabs">
    <view class="tab-item {{activeTab === 'finished' ? 'active' : ''}}" bindtap="switchTab" data-tab="finished">成品库存</view>
    <view class="tab-item {{activeTab === 'parts' ? 'active' : ''}}" bindtap="switchTab" data-tab="parts">配件库存</view>
  </view>

  <view class="warehouse-filter">
    <view class="filter-item {{selectedOrgId === '' ? 'active' : ''}}" bindtap="filterWarehouse" data-org-id="">全部组装厂</view>
    <view wx:for="{{orgOptions}}" wx:key="_id" class="filter-item {{selectedOrgId === item._id ? 'active' : ''}}" bindtap="filterWarehouse" data-org-id="{{item._id}}">
      {{item.name}}
    </view>
  </view>

  <block wx:if="{{activeTab === 'finished'}}">
    <view wx:if="{{filteredFinished.length === 0 && !loading}}" class="card empty-card">
      <text class="empty-text">暂无成品库存数据</text>
    </view>
    <view wx:for="{{filteredFinished}}" wx:key="id" class="card inv-card">
      <view class="inv-header">
        <view>
          <text class="inv-sku">{{item.itemName}}</text>
          <text class="inv-product">{{item.orgName}}</text>
        </view>
      </view>
      <view class="inv-detail">
        <view class="stock-grid">
          <view class="stock-item">
            <text class="inv-qty">{{item.finishedQty}}</text>
            <text class="inv-unit">成品</text>
          </view>
          <view class="stock-item">
            <text class="stock-sub">{{item.semiQty}}</text>
            <text class="inv-unit">半成品</text>
          </view>
          <view class="stock-item">
            <text class="stock-sub">{{item.wipQty}}</text>
            <text class="inv-unit">在制品</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'parts'}}">
    <view wx:if="{{filteredParts.length === 0 && !loading}}" class="card empty-card">
      <text class="empty-text">暂无配件库存数据</text>
    </view>
    <view wx:for="{{filteredParts}}" wx:key="id" class="card inv-card">
      <view class="inv-header">
        <view>
          <text class="inv-sku">{{item.itemName}}</text>
          <text class="inv-product">{{item.orgName}}</text>
        </view>
      </view>
      <view class="inv-detail">
        <view class="stock-grid">
          <view class="stock-item">
            <text class="inv-qty">{{item.finishedQty}}</text>
            <text class="inv-unit">成品</text>
          </view>
          <view class="stock-item">
            <text class="stock-sub">{{item.semiQty}}</text>
            <text class="inv-unit">半成品</text>
          </view>
          <view class="stock-item">
            <text class="stock-sub">{{item.wipQty}}</text>
            <text class="inv-unit">在制品</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
