.welcome-section { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0 24rpx; }
.welcome-greeting { font-size: var(--font-size-xl); font-weight: 700; color: #059669; display: block; }
.welcome-name { font-size: var(--font-size-sm); color: var(--color-text-secondary); display: block; margin-top: 4rpx; }
.stats-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; margin-bottom: 8rpx; }
.module-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-bottom: 16rpx; }
.module-card { min-height: 200rpx; display: flex; flex-direction: column; }
.module-icon { font-size: 40rpx; margin-bottom: 12rpx; }
.module-title { font-size: var(--font-size-base); font-weight: 700; color: var(--color-text-primary); display: block; }
.module-desc { font-size: var(--font-size-sm); color: var(--color-text-secondary); display: block; margin-top: 8rpx; flex: 1; }
.module-stat { font-size: var(--font-size-sm); color: #059669; font-weight: 600; display: block; margin-top: 12rpx; }
.batch-hint-card { border-left: 6rpx solid #D97706; margin-bottom: 16rpx; }
.batch-hint-title { font-size: var(--font-size-base); font-weight: 600; color: #92400E; display: block; margin-bottom: 8rpx; }
.batch-hint-text { font-size: var(--font-size-sm); color: #92400E; line-height: 1.7; display: block; }
.permission-notice { padding: 16rpx 24rpx; background: #FEF3C7; border-radius: var(--radius-md); margin-bottom: 16rpx; }
.notice-text { font-size: 24rpx; color: #92400E; }
.qc-entry { padding: 24rpx 32rpx !important; }
.qc-entry-part { font-size: var(--font-size-base); font-weight: 600; }
.qc-entry-info { font-size: var(--font-size-sm); color: var(--color-text-secondary); display: block; margin-top: 4rpx; }
.qc-entry-result { margin-top: 12rpx; padding: 12rpx 16rpx; background: var(--color-bg-page); border-radius: var(--radius-md); font-size: var(--font-size-sm); }
.result-pass { color: #059669; font-weight: 500; display: block; }
.result-partial { color: #D97706; font-weight: 500; display: block; }
.todo-item { display: flex; align-items: center; padding: 24rpx !important; }
.todo-icon { width: 64rpx; height: 64rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; margin-right: 20rpx; flex-shrink: 0; }
.todo-icon.info { background: #D1FAE5; }
.todo-content { flex: 1; min-width: 0; }
.todo-title { font-size: var(--font-size-base); font-weight: 500; display: block; }
.todo-desc { font-size: var(--font-size-sm); color: var(--color-text-secondary); display: block; margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.todo-time { font-size: var(--font-size-xs); color: var(--color-text-placeholder); display: block; margin-top: 4rpx; }
.progress-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.progress-text { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.progress-percent { font-size: var(--font-size-base); font-weight: 600; color: #059669; }
