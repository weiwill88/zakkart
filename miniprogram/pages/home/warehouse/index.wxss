.welcome-section { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0 24rpx; }
.welcome-greeting { font-size: var(--font-size-xl); font-weight: 700; color: #7C3AED; display: block; }
.welcome-name { font-size: var(--font-size-sm); color: var(--color-text-secondary); display: block; margin-top: 4rpx; }
.stats-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; margin-bottom: 8rpx; }
.quick-actions { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16rpx; margin-bottom: 16rpx; }
.action-btn { display: flex; flex-direction: column; align-items: center; padding: 28rpx 0; background: var(--color-bg-card); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); }
.action-btn:active { opacity: 0.8; }
.action-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.action-label { font-size: var(--font-size-xs); color: var(--color-text-secondary); }
.inventory-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20rpx; }
.inventory-item { display: flex; flex-direction: column; align-items: center; padding: 16rpx; border-radius: var(--radius-md); background: var(--color-bg-page); }
.inventory-item.low-stock { background: #FEF2F2; }
.inv-sku { font-size: var(--font-size-xs); color: var(--color-text-secondary); margin-bottom: 4rpx; }
.inv-qty { font-size: var(--font-size-2xl); font-weight: 700; color: var(--color-text-primary); }
.inv-qty.danger { color: var(--color-danger); }
.inv-label { font-size: var(--font-size-xs); color: var(--color-text-placeholder); }
