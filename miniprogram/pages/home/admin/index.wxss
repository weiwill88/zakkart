.welcome-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 24rpx;
}

.welcome-greeting {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
}

.welcome-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
}

.stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.module-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.module-card {
  padding: 24rpx !important;
}

.module-icon {
  font-size: 36rpx;
  display: block;
}

.module-title {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-size-base);
  font-weight: 600;
}

.module-desc {
  display: block;
  margin-top: 6rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 24rpx !important;
}

.todo-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.todo-icon.urgent { background: #FEE2E2; }
.todo-icon.warning { background: #FEF3C7; }
.todo-icon.normal { background: #DBEAFE; }
.todo-icon.info { background: #E0E7FF; }

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-title {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--color-text-primary);
  display: block;
}

.todo-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  display: block;
  margin-top: 4rpx;
}

.progress-card {
  padding: 28rpx 32rpx !important;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.progress-percent {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-primary);
}

.batch-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.batch-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.alert-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx !important;
}

.alert-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.alert-content {
  flex: 1;
}

.alert-title {
  font-size: var(--font-size-base);
  font-weight: 500;
  display: block;
}

.alert-desc {
  font-size: var(--font-size-sm);
  color: var(--color-danger);
  display: block;
  margin-top: 4rpx;
}

.alert-warehouse {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  display: block;
  margin-top: 4rpx;
}
