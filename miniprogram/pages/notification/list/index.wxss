.notif-item { padding: 24rpx 32rpx !important; position: relative; }
.notif-item.unread { border-left: 6rpx solid var(--color-primary); }
.notif-header { display: flex; }
.notif-type-icon { font-size: 36rpx; margin-right: 16rpx; flex-shrink: 0; }
.notif-content { flex: 1; min-width: 0; }
.notif-title { font-size: var(--font-size-base); font-weight: 600; }
.notif-time { font-size: 20rpx; color: var(--color-text-placeholder); flex-shrink: 0; }
.notif-text { font-size: var(--font-size-sm); color: var(--color-text-secondary); display: block; margin-top: 6rpx; line-height: 1.5; }
.unread-dot { position: absolute; top: 24rpx; right: 24rpx; width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--color-danger); }
