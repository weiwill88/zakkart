.agreement-page {
  padding: 40rpx 32rpx 80rpx;
  background: #fff;
  min-height: 100vh;
}

.agreement-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  text-align: center;
}

.update-date {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 40rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-heading {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.section-body {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
  white-space: pre-wrap;
}
