<view class="login-page">
  <view class="hero-card">
    <view class="title">Zakkart 供应链系统</view>
    <view class="subtitle">供应商及合作方专用入口，请使用管理员分配的手机号登录。</view>

    <view class="form-section">
      <view class="label">手机号</view>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{mobile}}" bindinput="onMobileInput" />

      <view class="label">验证码</view>
      <view class="code-row">
        <input class="input" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" />
        <button class="ghost-btn" size="mini" loading="{{sendingCode}}" disabled="{{sendingCode || countdown > 0}}" bindtap="sendCode">
          {{countdown > 0 ? countdown + 's' : '发送验证码'}}
        </button>
      </view>

      <view class="agreement-row" bindtap="toggleAgreed">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}" class="checkbox-icon">✓</text>
        </view>
        <view class="agreement-text">
          我已阅读并同意
          <text class="agreement-link" catchtap="openAgreement" data-type="service">《用户服务协议》</text>
          和
          <text class="agreement-link" catchtap="openAgreement" data-type="privacy">《隐私政策》</text>
        </view>
      </view>

      <button class="primary-btn" loading="{{submitting}}" bindtap="submit">登录系统</button>
    </view>
  </view>
</view>
