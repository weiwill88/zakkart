.login-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background:
    radial-gradient(circle at top left, rgba(26, 86, 219, 0.18), transparent 30%),
    linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
}

.hero-card {
  margin-top: 60rpx;
  padding: 40rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.title {
  margin-top: 20rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtitle {
  margin-top: 12rpx;
  color: #475569;
  line-height: 1.7;
}

.form-section {
  margin-top: 40rpx;
}

.label {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #0f172a;
}

.input {
  width: 100%;
  height: 88rpx;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #dbeafe;
}

.code-row {
  display: grid;
  grid-template-columns: 1fr 220rpx;
  gap: 16rpx;
  align-items: start;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  margin: 24rpx 0 12rpx;
  padding: 0 4rpx;
}

.checkbox {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 8rpx;
  margin-top: 4rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.checkbox.checked {
  background: #1d4ed8;
  border-color: #1d4ed8;
}

.checkbox-icon {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.agreement-text {
  flex: 1;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.agreement-link {
  color: #1d4ed8;
}

.primary-btn {
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #1d4ed8;
  color: #fff;
}

.ghost-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 20rpx;
  background: #eff6ff;
  color: #1d4ed8;
}
