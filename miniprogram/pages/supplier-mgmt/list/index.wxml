<!--pages/supplier-mgmt/list/index.wxml - 供应商列表-->
<view class="page-container">
  <view wx:for="{{suppliers}}" wx:key="id" class="card" style="padding: 28rpx 32rpx !important" bindtap="goToDetail" data-id="{{item.id}}">
    <view class="flex-between" style="margin-bottom: 8rpx">
      <text style="font-size: 30rpx; font-weight: 600">{{item.name}}</text>
      <view class="badge {{item.statusClass}}">{{item.statusText}}</view>
    </view>
    <view class="info-row"><text class="info-label">联系人</text><text class="info-value">{{item.contact}} · {{item.phone}}</text></view>
    <view class="info-row"><text class="info-label">配件类型</text><text class="info-value">{{item.type}}</text></view>
    <view class="info-row"><text class="info-label">地址</text><text class="info-value">{{item.address}}</text></view>
    <view style="display: flex; gap: 16rpx; margin-top: 12rpx">
      <view style="flex: 1; text-align: center; padding: 12rpx; background: #F3F4F6; border-radius: 12rpx">
        <text style="font-size: 32rpx; font-weight: 700; color: #1A56DB; display: block">{{item.contracts}}</text>
        <text style="font-size: 22rpx; color: #6B7280">总合同数</text>
      </view>
      <view style="flex: 1; text-align: center; padding: 12rpx; background: #F3F4F6; border-radius: 12rpx">
        <text style="font-size: 32rpx; font-weight: 700; color: #D97706; display: block">{{item.activeContracts}}</text>
        <text style="font-size: 22rpx; color: #6B7280">执行中</text>
      </view>
    </view>
  </view>
</view>
